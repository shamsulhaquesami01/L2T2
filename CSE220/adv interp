import numpy as np

def interpolate_signal_custom_step(t: np.ndarray, x: np.ndarray, q: np.ndarray, step: int = 2):
    """
    Interpolates using an arbitrary step size. 
    If step=2, anchors will snap to indices 0, 2, 4, 6, etc.
    """
    # 1. Raw Binary Search
    # This gives us the exact insertion index, just like std::lower_bound
    raw_idx = np.searchsorted(t, q, side="left")
    
    # 2. Grid Snapping Math (The C++ integer division trick)
    # Example: If raw_idx is 3 (q is between t[2] and t[3]), we want idx_l to snap to 2.
    # (3 - 1) // 2 = 1. Then 1 * 2 = 2.
    # Example 2: If raw_idx is 4 (q is between t[3] and t[4]), we want idx_l to snap to 2.
    # (4 - 1) // 2 = 1. Then 1 * 2 = 2.
    idx_l = ((raw_idx - 1) // step) * step
    
    # Protect against negative bounds (if query is smaller than t[0])
    idx_l = np.clip(idx_l, 0, len(t) - 1)
    
    # 3. Calculate Right Index
    # The right index is simply 'step' elements away from the left anchor
    idx_r = idx_l + step
    
    # 4. Out-of-Bounds Protection (Crucial!)
    # If we are near the end of the array, idx_l + step might exceed the array size.
    # We MUST clip it to the final valid index.
    idx_r = np.clip(idx_r, 0, len(t) - 1)
    
    # 5. Extract values
    tL, tR = t[idx_l], t[idx_r]
    xL, xR = x[idx_l], x[idx_r]
    
    # 6. Safe Weight Calculation
    # WARNING: Because we clipped idx_r, at the very end of the array, 
    # idx_l might equal idx_r. Your np.where(tR != tL, ...) logic perfectly 
    # prevents the fatal Division By Zero exception here!
    w = np.where(tR != tL, (q - tL) / (tR - tL), 0.0)
    
    # 7. Apply Point-Slope Formula
    return xL + w * (xR - xL)
